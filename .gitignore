# --- Secrets ---
# Local API keys — never commit this file
.env
# ...but DO commit the placeholder template so others know what keys are needed
!.env.example

# --- Python ---
# The virtual environment is rebuildable; no need to commit it
venv/
__pycache__/
*.pyc

# Packaging / build output and test caches. `/dist/` is root-anchored so it
# ignores Python packaging output but NOT the committed webapp/frontend/dist.
*.egg-info/
/dist/
build/
.pytest_cache/

# --- macOS ---
.DS_Store

# --- Local-only files (kept on my machine, not pushed to the repo) ---
project_timeline.html

# --- Local database (rebuildable from the fetchers; can grow large) ---
*.db
# SQLite WAL-mode sidecar files (created at runtime; never commit)
*.db-wal
*.db-shm

# --- Frontend (React/Vite) ---
# node_modules is rebuildable — never commit it. The built frontend (dist/) IS
# committed on purpose: FastAPI serves it, so a clone runs ./start.sh with no
# npm build step.
webapp/frontend/node_modules/
# The frontend .env files only hold the public VITE_API_BASE_URL (no secret) and
# the build needs them — re-include despite the global .env rule above.
!webapp/frontend/.env
!webapp/frontend/.env.production
