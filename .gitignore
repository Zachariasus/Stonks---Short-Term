# --- Secrets ---
# Local API keys — never commit this file
.env
# ...but DO commit the placeholder template so others know what keys are needed
!.env.example

# --- Python ---
# The virtual environment is rebuildable; no need to commit it
venv/
__pycache__/
*.pyc

# Packaging / build output and test caches
*.egg-info/
dist/
build/
.pytest_cache/

# --- macOS ---
.DS_Store

# --- Local-only files (kept on my machine, not pushed to the repo) ---
project_timeline.html

# --- Local database (rebuildable from the fetchers; can grow large) ---
*.db

# --- Frontend (React/Vite) ---
# Installed packages and build output are rebuildable — never commit them.
webapp/frontend/node_modules/
webapp/frontend/dist/
# The frontend .env only holds the public VITE_API_BASE_URL (no secret), and the
# build needs it — re-include it despite the global .env rule above.
!webapp/frontend/.env
